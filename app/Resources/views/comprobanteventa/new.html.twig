    function fnArticuloChange($index) {
        var data = { articuloId: $('#appbundle_comprobante_articulos_'+$index+'_articulo').val() };
        
        $.ajax({
            type: 'POST',
            url: "{{ url('articulo_find') }}" ,
            data: data,
            success: function(resp){
                var articulo = $.parseJSON(resp.articulo);
                
                $("#appbundle_comprobante_articulos_"+$index+"_precioUnitario").val(articulo.precioCosto);
            }
        });
    }

    function addArticuloFormDeleteLink($articuloFormLi) {
        var $removeFormA = $('<a href="#">Eliminar </a>');

        $articuloFormLi.append($removeFormA);

        $removeFormA.on('click', function (e) {
            // prevent the link from creating a "#" on the URL
            e.preventDefault();

            // remove the li for the articulo form
            $articuloFormLi.remove();
        });
    }

