{% extends 'base.html.twig' %}

{% block header %}
Nuevo Comprobante de Venta
{% endblock %}

{% block header_description %}
{% endblock %}

{% block extra_js %}
    <script src="{{ asset('js/jquery.collection.js') }}"></script>
{% endblock %}

{% block body %}

<div class="row">
    <div class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
        {{ form_start(form) }}
        <div class="box box-success">
            <div class="box-header with-border">
                <h3 class="box-title"><i class="fa fa-user"></i> Datos Generales</h3>
            </div>
            <div class="box-body">
                {{ form_errors(form) }}
                <div class="row">           
                    {{ form_widget(form.proveedor, { 'attr': {'class': 'hide'} })}}
                    {{ form_widget(form.numero, { 'attr': {'class': 'hide'} })}}
                    {{ form_widget(form.totalNoGravado, { 'attr': {'class': 'hide'} })}}
                    {{ form_widget(form.importeIvaExento, { 'attr': {'class': 'hide'} })}}
                    {{ form_widget(form.totalCosto, { 'attr': {'class': 'hide'} })}}
                    {{ form_widget(form.importeTributos, { 'attr': {'class': 'hide'} })}}         
                    <div class="col-xs-2 col-sm-2 col-md-2 col-lg-2">
                        {{ form_row(form.cliente)}}
                    </div>
                    <div class="col-xs-2 col-sm-2 col-md-2 col-lg-2">
                        {{ form_row(form.tipo)}}
                    </div>
                    <div class="col-xs-2 col-sm-2 col-md-2 col-lg-2">
                        {{ form_row(form.fecha)}}
                    </div>

                    <div class="col-xs-2 col-sm-2 col-md-2 col-lg-2">    
                        {{ form_row(form.puntoVenta)}}
                    </div>  
                </div>  
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
        <div class="box box-success">
            <div class="box-header with-border">
                <h3 class="box-title"><i class="fa fa-user"></i> Totales </h3>
            </div>
            <div class="box-body">                
                <div class="row">      
                    <div class="col-xs-2 col-sm-2 col-md-2 col-lg-2">    
                        {{ form_row(form.totalNeto)}}
                    </div>   
                    <div class="collection-xs-2 col-sm-2 col-md-2 col-lg-2">    
                        {{ form_row(form.importeIva)}}
                    </div> 
                    <div class="col-xs-2 col-sm-2 col-md-2 col-lg-2">    
                        {{ form_row(form.total)}}
                    </div>
                    <div class="col-xs-2 col-sm-2 col-md-2 col-lg-2">    
                    </div>
                    <div class="col-xs-2 col-sm-2 col-md-2 col-lg-2">    
                        {{ form_row(form.totalBonificacion)}}
                    </div> 
                    <div class="col-xs-2 col-sm-2 col-md-2 col-lg-2">    
                        {{ form_row(form.totalGanancia)}}
                    </div>    
                </div>  
            </div>
        </div>
    </div>
</div>

{% form_theme form 'comprobanteventa/formCollection.html.twig' %}
{{ form(form) }}

<div class="row">
    <div class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
        <div class="box box-success">
            <div class="box-footer">
                <div class="row">
                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                        <a href="{{ path('comprobanteventa_index') }}" class="btn btn-app">
                            <i class="fa fa-arrow-left"></i> Volver
                        </a>
                    </div>
                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                        <button type="submit" class="btn btn-app pull-right"><i class="fa fa-floppy-o"></i> Guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>    



<script type="text/javascript">
    $('.articulo-collection').collection({
        allow_duplicate: false,
        allow_up: false,
        allow_down: false,
        init_with_n_elements: 1,
        add_at_the_end: true,
        add: '<a href="#" class="btn btn-default" title="Add element"><span class="glyphicon glyphicon-plus-sign"></span></a>',
        elements_selector: 'tr.item',
        elements_parent_selector: '%id% tbody',
        after_add: function(collection, element) {
            articulo = element.find("select.articulo");
            //alert(articulo_select.prop('outerHTML'));
            
            articulo.on('change', function(){
                fnArticuloChange($(this));
            });

            element.on('change', function(){
                fnRenglonChange($(this));
            });

            return true;
         },
         after_remove: function(collection, element) {
            //Recalculo todos los totales
            fnCalcularTotales();

            return true;
         }
    });

    function fnArticuloChange(articulo) {
        var data = { articuloId: articulo.val() };
        var renglon = articulo.closest("tr");
        var precio_unitario = renglon.find("input.precioUnitario");
        var importe_iva = renglon.find("input.importeIva");
        
        $.ajax({
            type: 'POST',
            url: "{{ url('articulo_find') }}" ,
            data: data,
            success: function(resp){
                var articulo = $.parseJSON(resp.articulo);
                
                precio_unitario.val(articulo.precioCosto);
                importe_iva.val(articulo.iva);
                fnRenglonChange(renglon);
            }
        });

        return true;
    }

    function fnRenglonChange(renglon) {
        var cantidad = renglon.find("input.cantidad");
        var bonificacion = renglon.find("input.bonificacion");
        var precioUnitario = renglon.find("input.precioUnitario");
        var importeIva = renglon.find("input.importeIva");
        var total = renglon.find("input.total");

        var total_f = (cantidad.val() * precioUnitario.val() * (1+importeIva.val()/100)- bonificacion.val()).toFixed(3);
        total.val(total_f);   
        
        fnCalcularTotales();

        return true;
    }

    function fnCalcularTotales() {
        //Acá deberían estar los cálculos para cargar los datos
        //de la sección "TOTALES"
    }

