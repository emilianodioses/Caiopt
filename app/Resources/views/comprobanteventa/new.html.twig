{% extends 'base.html.twig' %}

{% block header %}
Nuevo Comprobante de Venta
{% endblock %}

{% block header_description %}
{% endblock %}

{% block extra_js %}
    <script src="{{ asset('js/jquery.collection.js') }}"></script>
{% endblock %}

{% block body %}  

<script>
$(function(){
    var hash = window.location.hash;
    hash && $('ul.nav a[href="' + hash + '"]').tab('show');

    $('.nav-tabs a').click(function (e) {
      $(this).tab('show');
      var scrollmem = $('body').scrollTop() || $('html').scrollTop();
      window.location.hash = this.hash;
      $('html,body').scrollTop(scrollmem);
    });
  });
</script>  

{% form_theme form 'comprobanteventa/formCollection.html.twig' %}
{{ form(form) }}
{{ form_end(form) }}

<script type="text/javascript">
    /*
    $(document).ready(function() {
        $('.js-example-basic-single').select2();
    });
    */
    $('.comprobanteDetalle-collection').collection({
        allow_duplicate: false,
        allow_up: false,
        allow_down: false,
        init_with_n_elements: 1,
        add_at_the_end: true,
        add: '<a href="#" class="btn btn-default" title="Add element"><span class="glyphicon glyphicon-plus-sign"></span></a>',
        elements_selector: 'tr.item',
        elements_parent_selector: '%id% tbody',
        after_add: function(collection, element) {
            articulo = element.find("select.articulo");
            //alert(articulo_select.prop('outerHTML'));
            
            articulo.on('change', function(){
                fnArticuloChange($(this));
            });

            element.on('change', function(){
                fnRenglonChange($(this));
            });

            //Inicializo el Select2 recién añadido
            //Fuente: https://select2.org/data-sources/ajax
            articulo.select2({
                ajax: {
                  delay: 250,
                  url: "{{ url('articulo_find_select2') }}",//+"?page_limit=10",
                  data: function (params) {
                    var queryParameters = {
                      q: params.term
                    }

                    return queryParameters;
                  },
                  processResults: function (data) {
                    return {
                      results: data
                    };
                  },
                },
                width: "100%",
            });

            return true;
         },
         after_remove: function(collection, element) {
            //Recalculo todos los totales
            fnCalcularTotales();

            return true;
         }
    });

    function fnArticuloChange(articulo) {
        var data = { articuloId: articulo.val() };
        var renglon = articulo.closest("tr");
        var precio_venta = renglon.find("input.precioVenta");
        var precio_costo = renglon.find("input.precioCosto");
        var importe_iva = renglon.find("input.importeIva");
        
        $.ajax({
            type: 'POST',
            url: "{{ url('articulo_find') }}" ,
            data: data,
            success: function(resp){
                var articulo = $.parseJSON(resp.articulo);
                
                precio_venta.val(articulo.precioVenta)
                precio_costo.val(articulo.precioCosto)
                importe_iva.val(parseFloat(articulo.iva.descripcion));
                fnRenglonChange(renglon);
            }
        });

        return true;
    }

    function fnRenglonChange(renglon) {
        var cantidad = renglon.find("input.cantidad");
        var bonificacion = renglon.find("input.bonificacion");
        var precioVenta = renglon.find("input.precioVenta");
        var importeIva = renglon.find("input.importeIva");
        var total = renglon.find("input.total");

        var total_neto_sin_iva = cantidad.val() * precioVenta.val();
        var total_neto = total_neto_sin_iva * (1+importeIva.val()/100)  ;
        var bonificacion =  total_neto * bonificacion.val()/100;
        var total_f = (total_neto - bonificacion).toFixed(3);
        total.val(total_f);   
        
        fnCalcularTotales();

        return true;
    }

    function fnCalcularTotales() {
        
        var total_neto = 0;
        var importe_iva = 0;
        var bonificacion = 0;
        var total = 0;
        var total_costo = 0;

        $("#ComprobanteType_comprobanteDetalles tr.item").each(function() {   
            var r_cantidad = $(this).find("input.cantidad");
            var r_bonificacion = $(this).find("input.bonificacion");
            var r_precioVenta = $(this).find("input.precioVenta");
            var r_precioCosto = $(this).find("input.precioCosto");
            var r_porcentajeIva = $(this).find("input.importeIva");
            var r_total = $(this).find("input.total");

            total_costo += parseFloat(r_cantidad.val()) * parseFloat(r_precioCosto.val()); 
            total_neto += parseFloat(r_cantidad.val()) * parseFloat(r_precioVenta.val());
            bonificacion += parseFloat(total_neto*r_bonificacion.val()/100);
            importe_iva += parseFloat((total_neto-bonificacion)*parseFloat(r_porcentajeIva.val()/100));
            total += parseFloat(r_total.val());
            //total += parseFloat(importe_iva);
        });


        $("#ComprobanteType_totalNeto").val(total_neto.toFixed(3));
        $("#ComprobanteType_importeIva").val(importe_iva.toFixed(3));
        $("#ComprobanteType_totalBonificacion").val(bonificacion.toFixed(3));
        $("#ComprobanteType_total").val(total.toFixed(3));

        $("#ComprobanteType_totalCosto").val(total_costo.toFixed(3));
        $("#ComprobanteType_totalGanancia").val(total.toFixed(3)-total_costo.toFixed(3));

        return true;
    }
    
    function submitform() {
            document.forms[0].submit();
            //document.getElementById('jsform').submit();
    }
</script>          

{% endblock %}