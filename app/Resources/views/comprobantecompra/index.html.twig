{% extends 'base.html.twig' %}

{% block header %}
Comprobantes de Compras
{% endblock %}

{% block header_description %}
{% endblock %}

{% block body %}

<form class="form-horizontal" action="{{path('comprobantecompra_index')}}" method="GET">
  <div class="row"> 
    <div class="col-xs-12">
      <div class="box">
        <div class="box-header">
          <h3 class="box-title"></h3>
          <div class="box-tools">
            <div class="input-group input-group-sm" style="width: 500px;">
              <input id="btn-input" type="text" class="form-control input-sm" 
                 name="texto" placeholder="Buscar por Nombre/Documento/Email/Contacto" value=""/>

              <span class="input-group-btn">
                  <button type="submit" class="btn btn-default"><i class="fa fa-search"></i></button>
                  <a type="button" class="btn btn-primary btn-md" href="{{ path('comprobantecompra_new') }}"><i class="fa fa-plus"></i> Nuevo</a>
              </span>
            </div>
          </div>
        </div>
        <!-- /.box-header -->
        <div class="box-body table-responsive no-padding">
          <table class="table table-hover">
                <tr>
                    <th>Tipo</th>
                    <th>Fecha</th>
                    <th>Puntoventa</th>
                    <th>Numero</th>
                    <th>Total</th>
                    <th>Observaciones</th>
                    <th style="width: 5%">Acciones</th>
                </tr>
            <tbody>
            {% for comprobante in comprobantes %}
                <tr>
                    <td>{{ comprobante.tipo }}</td>
                    <td>{{ comprobante.fecha|date('Y-m-d') }}</td>
                    <td>{{ comprobante.puntoVenta }}</td>
                    <td>{{ comprobante.numero }}</td>
                    <td>{{ comprobante.total }}</td>
                    <td>{{ comprobante.observaciones }}</td> 
                    <td>
                      <a href="{{ path('comprobantecompra_show', { 'id': comprobante.Id }) }}"><span class="glyphicon glyphicon-eye-open"></span>
                      </a>
                      <a href="{{ path('comprobantecompra_edit', { 'id': comprobante.Id }) }}"><span class="glyphicon glyphicon-edit"></span>
                      </a>
                      {% if comprobante.activo %}
                          <a href="{{ path('comprobantecompra_delete', { 'id': comprobante.Id }) }}" onclick="return confirm('Esta Seguro?')"><span class="glyphicon glyphicon-remove-sign"></span>
                          </a>
                      {% else %}
                          <a href="{{ path('comprobantecompra_delete', { 'id': comprobante.Id }) }}"><span class="glyphicon glyphicon-ok-circle"></span>
                          </a>
                      {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</form>
{% endblock %}
