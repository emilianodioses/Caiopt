{% extends 'base.html.twig' %}

{% block header %}
Usuarios
{% endblock %}

{% block header_description %}
{% endblock %}

{% block body %}

<div class="row">
        <div class="col-xs-12">
          <div class="box">
            <div class="box-header">
              <h3 class="box-title"></h3>

              <div class="box-tools">
                <div class="input-group input-group-sm" style="width: 150px;">
                  <input type="text" name="table_search" class="form-control pull-right" placeholder="Search">

                  <div class="input-group-btn">
                    <button type="submit" class="btn btn-default"><i class="fa fa-search"></i></button>
                  </div>
                </div>
              </div>
            </div>
            <!-- /.box-header -->
            <div class="box-body table-responsive no-padding">
              <table class="table table-hover">
                <tr>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Usuario</th>
                    <th>Email</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
                <tbody>
                {% for usuario in usuarios %}
                    <tr>
                        <td>{{ usuario.nombre }}</td>
                        <td>{{ usuario.apellido }}</td>
                        <td>{{ usuario.usuario }}</td>
                        <td>{{ usuario.email }}</td>
                        <td>{% if usuario.activo %}
                            <span class="label label-success">Activo</span>
                        {% else %}
                            <span class="label label-danger">Inactivo</span>
                        {% endif %}
                        </td>  
                        <td>
                            <a href="{{ path('usuario_show', { 'id': usuario.Id }) }}"><span class="glyphicon glyphicon-eye-open"></span>
                            </a>
                            <a href="{{ path('usuario_edit', { 'id': usuario.Id }) }}"><span class="glyphicon glyphicon-edit"></span>
                            </a>
                            {% if usuario.activo %}
                              <a href="{{ path('usuario_edit', { 'id': usuario.Id }) }}"><span class="glyphicon glyphicon-remove-sign"></span>
                              </a>
                            {% else %}
                              <a href="{{ path('usuario_edit', { 'id': usuario.Id }) }}"><span class="glyphicon glyphicon-ok-circle"></span>
                            </a>

                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
              </table>
            </div>
            <!-- /.box-body -->
          </div>
          <!-- /.box -->
        </div>
      </div>
      <a href="{{ path('usuario_new') }}" class="btn btn-primary btn-md" role="button">Nuevo Usuario</a>
{% endblock %}