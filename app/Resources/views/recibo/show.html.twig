{% extends 'base.html.twig' %}

{% block body %}
    <h1>Recibo</h1>

    <table>
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ recibo.id }}</td>
            </tr>
            <tr>
                <th>Fecha</th>
                <td>{% if recibo.fecha %}{{ recibo.fecha|date('Y-m-d H:i:s') }}{% endif %}</td>
            </tr>
            <tr>
                <th>Numero</th>
                <td>{{ recibo.numero }}</td>
            </tr>
            <tr>
                <th>Total</th>
                <td>{{ recibo.total }}</td>
            </tr>
            <tr>
                <th>Pendiente</th>
                <td>{{ recibo.pendiente }}</td>
            </tr>
            <tr>
                <th>Saldo</th>
                <td>{{ recibo.saldo }}</td>
            </tr>
            <tr>
                <th>Activo</th>
                <td>{% if recibo.activo %}Yes{% else %}No{% endif %}</td>
            </tr>
            <tr>
                <th>Createdby</th>
                <td>{{ recibo.createdBy }}</td>
            </tr>
            <tr>
                <th>Createdat</th>
                <td>{% if recibo.createdAt %}{{ recibo.createdAt|date('Y-m-d H:i:s') }}{% endif %}</td>
            </tr>
            <tr>
                <th>Updatedby</th>
                <td>{{ recibo.updatedBy }}</td>
            </tr>
            <tr>
                <th>Updatedat</th>
                <td>{% if recibo.updatedAt %}{{ recibo.updatedAt|date('Y-m-d H:i:s') }}{% endif %}</td>
            </tr>
        </tbody>
    </table>

    <ul>
        <li>
            <a href="{{ path('recibo_index') }}">Back to the list</a>
        </li>
        <li>
            <a href="{{ path('recibo_edit', { 'id': recibo.id }) }}">Edit</a>
        </li>
        <li>
            {{ form_start(delete_form) }}
                <input type="submit" value="Delete">
            {{ form_end(delete_form) }}
        </li>
    </ul>
{% endblock %}
