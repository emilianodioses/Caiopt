{% extends 'base.html.twig' %}

{% block header %}
Nueva Orden de Optica
{% endblock %}

{% block header_description %}
{% endblock %}

{% block extra_js %}
    <script src="{{ asset('js/jquery.collection.js') }}"></script>
{% endblock %}

{% block body %}  

<script>
$(function(){
    var hash = window.location.hash;
    hash && $('ul.nav a[href="' + hash + '"]').tab('show');

    $('.nav-tabs a').click(function (e) {
      $(this).tab('show');
      var scrollmem = $('body').scrollTop() || $('html').scrollTop();
      window.location.hash = this.hash;
      $('html,body').scrollTop(scrollmem);
    });
  });
</script>  

{% form_theme form 'ordentrabajo/formCollection.html.twig' %}
{{ form(form) }}
{{ form_end(form) }}

<script type="text/javascript">


    $('.cliente').change(function() {
        fnClienteChange($(this));
    });

    $('.ordenTrabajoDetalle-collection').collection({
        allow_duplicate: false,
        allow_up: false,
        allow_down: false,
        init_with_n_elements: 1,
        add_at_the_end: true,
        add: '<a href="#" class="btn btn-default" title="Agregar Artículo"><span class="glyphicon glyphicon-plus-sign"></span></a>',
        elements_selector: 'tr.item',
        elements_parent_selector: '%id% tbody',
        after_add: function(collection, element) {
            articulo = element.find("select.articulo"); 
            entrega = element.find("OrdenTrabajoType_entrega");
            
            articulo.on('change', function(){ 
                fnArticuloChange($(this));
            });

            element.on('change', function(){
                fnRenglonChange($(this));
            });

            articulo.select2({
                ajax: {
                  delay: 250,
                  url: "{{ url('articulo_find_select2') }}",//+"?page_limit=10",
                  data: function (params) {
                    var queryParameters = {
                      q: params.term
                    }

                    return queryParameters;
                  },
                  processResults: function (data) {
                    return {
                      results: data
                    };
                  },
                },
                width: "100%",
            });

            entrega.on('change', function(){
                fnCalcularSaldo();
            });

            return true;
         },
         after_remove: function(collection, element) {
            //Recalculo todos los totales
            fnCalcularTotales();

            return true;
         }
    });

    function fnClienteChange(cliente) {

        var data = { clienteId: cliente.val() };

        $.ajax({
            type: 'POST',
            url: "{{ url('ordentrabajo_find') }}" ,
            data: data,
            success: function(resp){

                var ordentrabajo = $.parseJSON(resp.ordentrabajo);

                alert(ordentrabajo);
            
                $("#OrdenTrabajoType_antesLejosOjoDerechoEje").val(ordentrabajo.antesLejosOjoDerechoEje);
                $("#OrdenTrabajoType_antesLejosOjoIzquierdoEje").val(ordentrabajo.antesLejosOjoIzquierdoEje);
                $("#OrdenTrabajoType_antesLejosOjoDerechoCilindro").val(ordentrabajo.antesLejosOjoDerechoCilindro);
                $("#OrdenTrabajoType_antesLejosOjoIzquierdoCilindro").val(ordentrabajo.antesLejosOjoIzquierdoCilindro);
                $("#OrdenTrabajoType_antesLejosOjoDerechoEsfera").val(ordentrabajo.antesLejosOjoDerechoEsfera);
                $("#OrdenTrabajoType_antesLejosOjoIzquierdoEsfera").val(ordentrabajo.antesLejosOjoIzquierdoEsfera);
                $("#OrdenTrabajoType_antesCercaOjoDerechoEje").val(ordentrabajo.antesCercaOjoDerechoEje);
                $("#OrdenTrabajoType_antesCercaOjoIzquierdoEje").val(ordentrabajo.antesCercaOjoIzquierdoEje);
                $("#OrdenTrabajoType_antesCercaOjoDerechoCilindro").val(ordentrabajo.antesCercaOjoDerechoCilindro);
                $("#OrdenTrabajoType_antesCercaOjoIzquierdoCilindro").val(ordentrabajo.antesCercaOjoIzquierdoCilindro);
                $("#OrdenTrabajoType_antesCercaOjoDerechoEsfera").val(ordentrabajo.antesCercaOjoDerechoEsfera);
                $("#OrdenTrabajoType_antesCercaOjoIzquierdoEsfera").val(ordentrabajo.antesCercaOjoIzquierdoEsfera);
                $("#OrdenTrabajoType_antesOjoDerechoDnp").val(ordentrabajo.antesOjoDerechoDnp);
                $("#OrdenTrabajoType_antesOjoIzquierdoDnp").val(ordentrabajo.antesOjoIzquierdoDnp);
            }
        });
        

        return true;
    }

    function fnArticuloChange(articulo) {
        var data = { articuloId: articulo.val() };
        var renglon = articulo.closest("tr");

        var total = renglon.find("input.total");
        var porcentajeBonificacion = renglon.find("input.porcentajeBonificacion");
        var importeBonificacion = renglon.find("input.importeBonificacion");
        var precioVenta = renglon.find("input.precioVenta");

        $.ajax({
            type: 'POST',
            url: "{{ url('articulo_find') }}" ,
            data: data,
            success: function(resp){
                var articulo = $.parseJSON(resp.articulo);
                
                precioVenta.val(articulo.precioVenta);
                total.val(articulo.precioVenta);
                porcentajeBonificacion.val(0);
                importeBonificacion.val(0);

                fnRenglonChange(renglon);
            }
        });

        return true;
    }

    function fnRenglonChange(renglon) {
        var r_porcentajeBonificacion = renglon.find("input.porcentajeBonificacion");
        var r_importeBonificacion = renglon.find("input.importeBonificacion");
        var r_precioVenta = renglon.find("input.precioVenta");
        var r_total = renglon.find("input.total");


        var importeBonificacion = parseFloat(r_precioVenta.val()*r_porcentajeBonificacion.val()/100).toFixed(2);

        r_importeBonificacion.val(importeBonificacion);
        var total = parseFloat(r_precioVenta.val() - r_importeBonificacion.val()).toFixed(2);

        r_total.val(total);   
        
        fnCalcularTotales();

        return true;
    }

    function fnCalcularTotales() {

        var total_bonificacion = 0;
        var total = 0;
        
        $("#OrdenTrabajoType_ordenTrabajoDetalles tr.item").each(function() {

            var r_importeBonificacion = $(this).find("input.importeBonificacion");
            var r_total = $(this).find("input.total");

            total_bonificacion += parseFloat(r_importeBonificacion.val());
            total += parseFloat(r_total.val());
        });

        $("#OrdenTrabajoType_totalBonificacion").val(total_bonificacion.toFixed(2));
        $("#OrdenTrabajoType_total").val(total.toFixed(2));
        $("#OrdenTrabajoType_saldo").val(total.toFixed(2));
        
        fnCalcularSaldo();

        return true;
    }

    function fnCalcularSaldo() {

        total = $("#OrdenTrabajoType_total").val();
        entrega = $("#OrdenTrabajoType_entrega").val();

        var saldo = parseFloat(total - entrega);

        $("#OrdenTrabajoType_saldo").val(saldo.toFixed(2));
        
        return true;
    }

    $('#OrdenTrabajoType_entrega').change(function() {
       fnCalcularSaldo();
    });

</script>          

{% endblock %}