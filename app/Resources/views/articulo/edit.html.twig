{% extends 'base.html.twig' %}

{% block header %}
Articulo
{% endblock %}

{% block header_description %}
{% endblock %}

{% block body %}

<div class="row">
    {{ form_start(edit_form) }}
    <div class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
        <div class="row">
            <div class="col-xs-8 col-sm-8 col-md-8 col-lg-8">
                <div class="box box-success">
                    <div class="box-header with-border">
                        <h3 class="box-title"><i class="fa fa-user"></i> Datos Generales</h3>
                    </div>
                    <div class="box-body">
                        {{ form_errors(edit_form) }}
                        <div class="row">
                            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">
                                {{ form_row(edit_form.codigo) }}                            
                            </div>  
                            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">
                                {{ form_row(edit_form.descripcion) }}
                            </div>
                            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">
                                {{ form_row(edit_form.precioCosto) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">
                                {{ form_row(edit_form.gananciaPorcentaje) }}
                            </div> 
                            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">   
                                {{ form_row(edit_form.precioVenta) }}
                            </div>
                            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">
                                {{ form_row(edit_form.iva) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">
                                {{ form_row(edit_form.cantidad) }}
                            </div>
                            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">
                                {{ form_row(edit_form.cantidadMinima) }}
                            </div>
                            
                        </div>
                        <div class="row">
                            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">
                                {{ form_row(edit_form.activo) }}
                            </div>
                            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">
                                {{ form_row(edit_form.precioModifica) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xs-4 col-sm-4 col-md-4 col-lg-4">
                <div class="box box-info">
                    <div class="box-header with-border">
                        <h3 class="box-title"><i class="fa fa-user"></i> Caracteristicas</h3>
                    </div>
                    <div class="box-body">
                        {{ form_errors(edit_form) }}
                        <div class="row">
                            <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                                {{ form_row(edit_form.categoriaId) }}
                            </div>
                            <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                                {{ form_row(edit_form.marcaId) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                                {{ form_row(edit_form.genero) }}
                            </div>
                            <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                                {{ form_row(edit_form.estilo) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                                {{ form_row(edit_form.material) }}
                            </div>
                            <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                                {{ form_row(edit_form.forma) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                                {{ form_row(edit_form.color_marco) }}
                            </div>
                            <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                                {{ form_row(edit_form.color_cristal) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="box box-success">
            <div class="box-footer">
                <div class="row">
                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                        <a href="{{ path('articulo_index') }}" class="btn btn-app">
                            <i class="fa fa-arrow-left"></i> Volver
                        </a>
                    </div>
                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6">
                        <button type="submit" class="btn btn-app pull-right"><i class="fa fa-floppy-o"></i> Guardar</button>
                    </div>
                </div>
            </div>
        </div>
        {{ form_end(edit_form) }}
    </div>
</div>
{% endblock %}

